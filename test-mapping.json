{
  "app": {
    "description": "Root Tkinter GUI application",
    "test_paths": ["tests/"],
    "pytest_markers": "not serial",
    "parallel": true,
    "coverage_targets": ["app"]
  },
  "backend": {
    "description": "FastAPI backend service",
    "test_paths": ["backend/tests/", "backend/fastapi/tests/"],
    "pytest_markers": "not serial",
    "parallel": true,
    "coverage_targets": ["backend"],
    "requires_setup": true
  },
  "frontend-web": {
    "description": "Web frontend",
    "test_paths": ["frontend-web/tests/"],
    "pytest_markers": "not serial",
    "parallel": true,
    "skip_if_not_exists": true
  },
  "mobile-app": {
    "description": "Mobile application",
    "test_paths": ["mobile-app/tests/"],
    "pytest_markers": "not serial",
    "parallel": true,
    "skip_if_not_exists": true
  },
  "shared": {
    "description": "Shared code and utilities",
    "test_paths": ["tests/", "backend/tests/", "backend/fastapi/tests/"],
    "pytest_markers": "not serial",
    "parallel": true,
    "coverage_targets": ["app", "backend"]
  },
  "all": {
    "description": "Run all tests (fallback)",
    "test_paths": ["tests/", "backend/tests/", "backend/fastapi/tests/"],
    "pytest_markers": "not serial",
    "parallel": true,
    "coverage_targets": ["app", "backend"]
  }
}
